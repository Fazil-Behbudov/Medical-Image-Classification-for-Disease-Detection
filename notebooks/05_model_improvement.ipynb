      "140/140 [==============================] - 24s 168ms/step - loss: 0.7023 - accuracy: 0.7214 - val_loss: 0.9654 - val_accuracy: 0.7106 - lr: 0.0010\n",
      "Epoch 10/50\n",
      "140/140 [==============================] - 24s 169ms/step - loss: 0.6830 - accuracy: 0.7353 - val_loss: 1.3732 - val_accuracy: 0.6219 - lr: 0.0010\n",
      "Epoch 11/50\n",
      "140/140 [==============================] - 24s 170ms/step - loss: 0.6441 - accuracy: 0.7350 - val_loss: 1.0149 - val_accuracy: 0.7044 - lr: 5.0000e-04\n",
      "Epoch 12/50\n",
      "140/140 [==============================] - 24s 171ms/step - loss: 0.6355 - accuracy: 0.7542 - val_loss: 1.0753 - val_accuracy: 0.6900 - lr: 5.0000e-04\n"
     ]
    }
   ],
   "source": [
    "model = load_model('../results/baseline_model.keras')\n",
    "early_stopping = EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True)\n",
    "model_checkpoint = ModelCheckpoint('../results/best_model.keras', save_best_only=True, monitor='val_loss')\n",
    "lr_scheduler = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=3, min_lr=1e-7)\n",
    "history_improved_model = model.fit(datagen.flow(X_train, y_train, batch_size=32), epochs=50, validation_data=(X_val, y_test), callbacks=[early_stopping, model_checkpoint, lr_scheduler])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "feb5d49f",
   "metadata": {},
   "source": [
    "### 5. Evaluate the Augmented Model"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "633583d9",
   "metadata": {},
   "source": [
    "After re-training with augmented data, we need to evaluate the new model's performance on the test set to see if our changes have led to improvements."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "949ef22b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "50/50 [==============================] - 1s 24ms/step - loss: 0.9640 - accuracy: 0.6769\n",
      "Augmented Model Test Loss: 0.9640\n",
      "Augmented Model Test Accuracy: 0.6769\n"
     ]
    }
   ],
   "source": [
    "augmented_model = load_model('../results/best_model.keras')\n",
    "X_test_augmented = np.repeat(X_test, 3, axis=-1)\n",
    "test_loss, test_acc = augmented_model.evaluate(X_test_augmented, y_test)\n",
    "print(f'Augmented Model Test Loss: {test_loss:.4f}')\n",
    "print(f'Augmented Model Test Accuracy: {test_acc:.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "fb8f3e94",
   "metadata": {},
   "source": [
    "### 6. Detailed Comparison of Baseline and Augmented Models"
